{
  "name": "homebridge-xbloom",
  "displayName": "xBloom",
  "version": "0.1.3",
  "description": "Brew your saved xBloom coffee recipes from HomeKit/Siri over Bluetooth LE.",
  "author": "Abdulaziz Alharbi",
  "license": "MIT",
  "type": "module",
