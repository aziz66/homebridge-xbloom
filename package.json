  "homepage": "https://github.com/aziz66/homebridge-xbloom#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aziz66/homebridge-xbloom.git"
  },
  "bugs": {
    "url": "https://github.com/aziz66/homebridge-xbloom/issues"
  },
  "funding": {
    "type": "ko-fi",
    "url": "https://ko-fi.com/aziz66"
  },
  "keywords": [
    "homebridge-plugin",
    "xbloom",
    "coffee",
